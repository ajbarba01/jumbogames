// Prisma schema for jumbo-minigames. Data models land with milestone 1
// (see docs/ROADMAP.md). Connection URLs live in prisma.config.ts (CLI)
// and the driver adapter (runtime).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  player
  admin
  owner
}

/// Application mirror of a Supabase auth user, keyed by the same id. Created
/// lazily on first authenticated request. No FK to auth.users (different schema).
model Profile {
  id        String   @id
  email     String   @unique
  role      Role     @default(player)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}
