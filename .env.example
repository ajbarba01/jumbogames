# Copy to .env.local and fill in from your Supabase project settings.
# NEVER commit real values.

# Prisma — Supabase Postgres. DATABASE_URL uses the pooled connection (port 6543,
# pgbouncer); DIRECT_URL uses the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# Supabase client (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Comma-separated emails that receive the owner role on signup
OWNER_EMAILS="you@example.com"
